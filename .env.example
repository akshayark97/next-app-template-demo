# ---------------------------------------------------------------------------
# Environment variables — copy this file to .env.local and fill in your values.
#
#   cp .env.example .env.local
#
# Every variable is OPTIONAL. The app runs without them; features that depend
# on a missing variable are simply disabled or stubbed out.
# ---------------------------------------------------------------------------

# Database — Neon (Postgres) connection string
DATABASE_URL=

# Auth — Stack Auth (all three required to enable sign-in/sign-up)
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# Caching — Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Storage — Vercel Blob
BLOB_READ_WRITE_TOKEN=
# Public base URL of your Blob store (used for rendering uploaded images)
BLOB_BASE_URL=

# Transactional email — Resend
RESEND_API_KEY=

# Cron — shared secret to authorize scheduled/cron route invocations
CRON_SECRET=

# AI (optional) — only if you wire up an LLM provider in src/ai/.
# Set the key for whichever provider you install an adapter for, e.g.:
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
